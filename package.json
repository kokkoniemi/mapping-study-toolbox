{
  "name": "mapping-tool",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "start:dev": "node --watch server.js",
    "migrate": "node_modules/.bin/sequelize db:migrate",
    "ui:install": "npm --prefix ui install",
    "ui:dev": "npm --prefix ui run dev",
    "ui:build": "npm --prefix ui run build",
    "ui:preview": "npm --prefix ui run preview",
    "ui:lint": "npm --prefix ui run lint"
  },
  "bin": "server.js",
  "pkg": {
    "assets": [
      "./public/**/*",
      "./node_modules/sqlite3/build/**/*"
    ],
    "scripts": [
      "./node_modules/*",
      "./routes/*",
      "./models/*",
      "./migrations/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-linux-arm64",
      "node18-macos-arm64",
      "node18-win-x64"
    ],
    "compress": "GZip"
  },
  "dependencies": {
    "express": "^5.2.1",
    "sequelize": "^6.37.8",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "sequelize-cli": "^6.6.5"
  }
}
